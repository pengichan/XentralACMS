# appsetting.config
# Central configuration file for Xentral ACMS API

[app]
name=XentralACMSAPI
environment=development
timezone=Asia/Yangon

[server]
host=0.0.0.0
port=8080
read_timeout_seconds=30
write_timeout_seconds=30
idle_timeout_seconds=60

[database]
driver=sqlserver
host=localhost
port=1433
name=OrbitACMS
schema=dbo
username=<DB_USERNAME>
password=<DB_PASSWORD>
encrypt=false
trust_server_certificate=true
max_open_connections=25
max_idle_connections=10
connection_max_lifetime_minutes=30
connection_string=sqlserver://<DB_USERNAME>:<DB_PASSWORD>@localhost:1433?database=OrbitACMS&encrypt=disable
secondary_connection_string=sqlserver://<DB_USERNAME>:<DB_PASSWORD>@localhost:1433?database=OrbitACMS_Secondary&encrypt=disable


[jwt]
issuer=xentral-acms-api
secret_key=CHANGE_ME_TO_A_STRONG_SECRET_KEY
access_token_expiry_minutes=60
refresh_token_expiry_days=7

[cors]
allowed_origins=http://localhost:4200,http://127.0.0.1:4200
allowed_methods=GET,POST,PUT,DELETE,OPTIONS
allowed_headers=Content-Type,Authorization
allow_credentials=true

[swagger]
enabled=true
base_path=/swagger

[file_storage]
upload_root=./uploads
max_upload_size_mb=10

[logging]
level=info
format=text

[smtp]
enabled=false
host=smtp.example.com
port=587
username=<SMTP_USERNAME>
password=<SMTP_PASSWORD>
from=no-reply@XentralACMS.local
