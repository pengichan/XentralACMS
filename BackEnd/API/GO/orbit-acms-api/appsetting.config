# appsetting.config
# Central configuration file for Orbit ACMS API

[app]
name=OrbitACMSAPI
environment=development
timezone=Asia/Yangon

[server]
host=0.0.0.0
port=8080
read_timeout_seconds=30
write_timeout_seconds=30
idle_timeout_seconds=60

[database]
driver=sqlserver
host=YOUR_DB_HOST
port=1433
name=YOUR_DB_NAME
schema=dbo
username=YOUR_DB_USER
password=YOUR_DB_PASSWORD
encrypt=false
trust_server_certificate=true
max_open_connections=25
max_idle_connections=10
connection_max_lifetime_minutes=30
connection_string=sqlserver://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:1433?database=YOUR_DB_NAME&encrypt=disable

[jwt]
issuer=orbit-acms-api
secret_key=CHANGE_ME_TO_A_STRONG_SECRET_KEY
access_token_expiry_minutes=60
refresh_token_expiry_days=7

[cors]
allowed_origins=http://localhost:4200,http://127.0.0.1:4200
allowed_methods=GET,POST,PUT,DELETE,OPTIONS
allowed_headers=Content-Type,Authorization
allow_credentials=true

[swagger]
enabled=true
base_path=/swagger

[file_storage]
upload_root=./uploads
max_upload_size_mb=10

[logging]
level=info
format=text

